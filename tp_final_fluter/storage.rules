rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ── Room photo uploads ────────────────────────────────────────────────────
    // Path: rooms/{roomId}/rounds/{roundNumber}/{uid}.jpeg
    match /rooms/{roomId}/rounds/{roundNumber}/{fileName} {
      // Any authenticated user can read photos (needed to display vote gallery).
      allow read: if request.auth != null;

      // Writes: must be authenticated, file ≤ 5 MB, must be an image.
      // The filename is {uid}.jpeg so we also verify the uploader owns the file.
      allow write: if request.auth != null
        && request.resource.size <= 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
  }
}
